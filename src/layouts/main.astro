---
import Navbar from "@/blocks/navbar.astro"
import "@/styles/global.css"
const { title } = Astro.props
---

<script is:inline>
  const getThemePreference = () => {
    if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
      return localStorage.getItem("theme")
    }
    return window.matchMedia("(prefers-color-scheme: dark)").matches
      ? "dark"
      : "light"
  }
  const isDark = getThemePreference() === "dark"
  document.documentElement.classList[isDark ? "add" : "remove"]("dark")

  if (typeof localStorage !== "undefined") {
    const observer = new MutationObserver(() => {
      const isDark = document.documentElement.classList.contains("dark")
      localStorage.setItem("theme", isDark ? "dark" : "light")
    })
    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    })
  }
</script>

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Frontend developer specializing in React, TypeScript, and modern web technologies. Explore my projects, skills, and professional experience."
    />
    <!-- <link rel="icon" type="image/svg+xml" href="/favicon.svg" /> -->
    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml;base64,"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <main class="mx-auto max-w-5xl md:px-4">
      <Navbar />
      <slot />
    </main>
  </body>
</html>
